<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Colors -->
  <SolidColorBrush x:Key="AppBackground" Color="#111111" />
  <SolidColorBrush x:Key="KeyboardBackground" Color="#1C1C1C" />
  <SolidColorBrush x:Key="SpecialKeyBg" Color="#2A2A2A" />
  <SolidColorBrush x:Key="BlueAccent" Color="#2D8ECF" />
  <SolidColorBrush x:Key="BlueText" Color="#4AAFE0" />
  <SolidColorBrush x:Key="ToolbarBg" Color="#181818" />
  <SolidColorBrush x:Key="BorderBrush" Color="#2A2A2A" />
  <SolidColorBrush x:Key="TextColor" Color="#E0E0E0" />
  <SolidColorBrush x:Key="SubLabelColor" Color="#555555" />
  <SolidColorBrush x:Key="SuggestionBg" Color="#1A1A1A" />
  <SolidColorBrush x:Key="ErrorRed" Color="#E05555" />
  <SolidColorBrush x:Key="ClearRed" Color="#C0392B" />
  <SolidColorBrush x:Key="UndoGray" Color="#555555" />
  <SolidColorBrush x:Key="PhrasesGreen" Color="#2A6E3F" />
  <SolidColorBrush x:Key="PhrasesBg" Color="#222222" />
  <SolidColorBrush x:Key="PredictionBorder" Color="#333333" />

</ResourceDictionary>
